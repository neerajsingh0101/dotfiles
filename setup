#!/usr/bin/env ruby
require 'fileutils'


# Load .devbox env (read DEVBOXD from the environment)
DEVBOXD = ENV.fetch("DEVBOXD")
DOTFILESD = "#{DEVBOXD}/dotfiles"


FileUtils.mkdir_p(File.expand_path("~/code/scratch"))
FileUtils.mkdir_p(File.expand_path("~/code/bigbinary"))
FileUtils.mkdir_p(File.expand_path("~/code/personal-stuff"))

# set a softlink of ~/.claude/settings.json to ~/code/devbox/dotfiles/.claude/settings.json
source = File.expand_path("~/code/devbox/dotfiles/.claude/settings.json")
target = File.expand_path("~/.claude/settings.json")
FileUtils.mkdir_p(File.dirname(target))
FileUtils.ln_sf(source, target)

### DISABLE GOOGLE CHROME PASSWORD MANAGER
puts "Disabling Google Chrome password manager..."
system(
  "/usr/bin/defaults",
  "write",
  "com.google.Chrome",
  "PasswordManagerEnabled",
  "-bool",
  "false"
)

# Restart macOS preferences cache so Chrome sees the change reliably.
system(
  "/usr/bin/killall",
  "cfprefsd",
  out: File::NULL,
  err: File::NULL
)

puts "Chrome password manager disabled."
puts "Open Chrome browser and visit chrome://policy and click 'Reload policies' to verify."

def link_force(src, dst)
  if src.to_s.empty? || dst.to_s.empty?
    abort "Usage: link_force <src> <dst>"
  end

  unless File.exist?(src) || File.symlink?(src)
    abort "Missing source: #{src}"
  end

  # Backup dst if it's a real file (not a symlink)
  if File.exist?(dst) && !File.symlink?(dst)
    backup = "#{dst}-bkp-#{Time.now.strftime('%Y%m%d%H%M%S')}"
    puts "Backing up #{dst} to #{backup}"
    FileUtils.mv(dst, backup)
  else
    FileUtils.rm_rf(dst)
  end

  FileUtils.ln_s(src, dst)
end

link_force("#{DOTFILESD}/symlinks/nvim", File.expand_path("~/.config/nvim"))

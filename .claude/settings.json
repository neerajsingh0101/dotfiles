{
  "$schema" : "https:\/\/json.schemastore.org\/claude-code-settings.json",
  "alwaysThinkingEnabled" : true,
  "effortLevel" : "xhigh",
  "enabledPlugins" : {
    "ruby-lsp@claude-plugins-official" : true,
    "swift-lsp@claude-plugins-official" : true
  },
  "hooks" : {
    "Notification" : [
      {
        "hooks" : [
          {
            "command" : "afplay \/System\/Library\/Sounds\/Glass.aiff",
            "type" : "command"
          },
          {
            "command" : "[ -n \"$WEZTERM_PANE\" ] && echo permission_prompt > \/tmp\/claude-wezterm-$WEZTERM_PANE",
            "type" : "command"
          },
          {
            "command" : "[ -n \"$NEETLY_SOCKET\" ] && neetly notify red || true",
            "type" : "command"
          }
        ],
        "matcher" : "permission_prompt"
      },
      {
        "hooks" : [
          {
            "command" : "'\/Applications\/Muxy.app\/Contents\/Resources\/Muxy_Muxy.bundle\/muxy-claude-hook.sh' notification # muxy-notification-hook",
            "timeout" : 10,
            "type" : "command"
          }
        ],
        "matcher" : ""
      }
    ],
    "PermissionRequest" : [
      {
        "hooks" : [
          {
            "command" : "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR\/hooks\/notify.sh\" ] && \"$SUPERSET_HOME_DIR\/hooks\/notify.sh\" || true",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "PostToolUse" : [
      {
        "hooks" : [
          {
            "command" : "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR\/hooks\/notify.sh\" ] && \"$SUPERSET_HOME_DIR\/hooks\/notify.sh\" || true",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "PostToolUseFailure" : [
      {
        "hooks" : [
          {
            "command" : "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR\/hooks\/notify.sh\" ] && \"$SUPERSET_HOME_DIR\/hooks\/notify.sh\" || true",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "Stop" : [
      {
        "hooks" : [
          {
            "command" : "afplay \/System\/Library\/Sounds\/Hero.aiff",
            "type" : "command"
          },
          {
            "command" : "[ -n \"$WEZTERM_PANE\" ] && echo done > \/tmp\/claude-wezterm-$WEZTERM_PANE",
            "type" : "command"
          },
          {
            "command" : "[ -n \"$NEETLY_SOCKET\" ] && neetly notify green || true",
            "type" : "command"
          }
        ]
      },
      {
        "hooks" : [
          {
            "command" : "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR\/hooks\/notify.sh\" ] && \"$SUPERSET_HOME_DIR\/hooks\/notify.sh\" || true",
            "type" : "command"
          }
        ]
      },
      {
        "hooks" : [
          {
            "command" : "'\/Applications\/Muxy.app\/Contents\/Resources\/Muxy_Muxy.bundle\/muxy-claude-hook.sh' stop # muxy-notification-hook",
            "timeout" : 10,
            "type" : "command"
          }
        ],
        "matcher" : ""
      }
    ],
    "UserPromptSubmit" : [
      {
        "hooks" : [
          {
            "command" : "[ -n \"$WEZTERM_PANE\" ] && rm -f \/tmp\/claude-wezterm-$WEZTERM_PANE",
            "type" : "command"
          },
          {
            "command" : "[ -n \"$NEETLY_SOCKET\" ] && neetly notify clear || true",
            "type" : "command"
          }
        ]
      },
      {
        "hooks" : [
          {
            "command" : "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR\/hooks\/notify.sh\" ] && \"$SUPERSET_HOME_DIR\/hooks\/notify.sh\" || true",
            "type" : "command"
          }
        ]
      }
    ]
  },
  "permissions" : {
    "allow" : [
      "Read(**)",
      "Read(~\/code\/neetozone\/**)",
      "Glob(**)",
      "Grep(*)",
      "Write(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "NotebookEdit(*)",
      "WebFetch(*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git mv *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git rebase *)",
      "Bash(git remote *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo *)",
      "Bash(gh status *)",
      "Bash(gh api *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(pwd *)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(bundle exec *)",
      "Bash(bundle install *)",
      "Bash(bin\/*)",
      "Bash(rake *)",
      "Bash(rails *)",
      "Bash(npm run *)",
      "Bash(npm list *)",
      "Bash(node --version *)",
      "Bash(pnpm run *)",
      "Bash(yarn *)",
      "Bash(bun run *)",
      "Bash(brew install *)",
      "Bash(pytest *)",
      "Bash(python -m pytest *)",
      "Bash(go test *)",
      "Bash(cargo test *)",
      "Bash(psql *)",
      "Bash(redis-cli *)",
      "Bash(ruby *)",
      "Bash(grep *)",
      "Bash(bundle show *)",
      "Bash(bundle update *)",
      "Bash(shasum *)"
    ],
    "deny" : [
      "Read(**\/secrets\/**)",
      "Read(**\/*.pem)",
      "Read(**\/*.key)",
      "Read(**\/.ssh\/**)",
      "Read(**\/.aws\/**)",
      "Bash(sudo *)",
      "Bash(chmod -R 777 *)"
    ]
  },
  "skipDangerousModePermissionPrompt" : true
}